# Arrived Investment Agent — frontend environment (spec §13, R23).
# Vite inlines VITE_* variables at build time; copy to `.env` to override.

# Base URL for every API request (frontend/src/api/client.ts).
# Default "/api" is same-origin: in Docker, nginx proxies /api/ -> api:8000 (§11).
VITE_API_URL=/api

# Local non-Docker dev (vite on 5173, uvicorn on 8000): point straight at the API.
# VITE_API_URL=http://localhost:8000/api
