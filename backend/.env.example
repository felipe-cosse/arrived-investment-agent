# Arrived Investment Agent — backend environment (spec §13).
# Copy to `.env` and fill in. Secrets live only here, never in code (R23).

# Anthropic — required only for POST /api/chat; everything else works offline (R21).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
MAX_TOKENS=4096
MAX_AGENT_TURNS=8
# Server-side chat history truncation (R17).
MAX_HISTORY_MESSAGES=40

# Storage — volume-mounted in docker compose.
DB_PATH=data/arrived.duckdb

# CORS — comma-separated; dev only (the nginx proxy makes prod same-origin).
CORS_ORIGINS=http://localhost:5173

# Enrichment sources — optional; each source skips cleanly when its key is absent.
FRED_API_KEY=
CENSUS_API_KEY=
# Zillow Research public CSVs (no key). Leave unset to use the adapter's
# canonical research-CSV defaults; set only to pin or test alternate exports:
#   https://files.zillowstatic.com/research/public_csvs/zhvi/Metro_zhvi_uc_sfrcondo_tier_0.33_0.67_sm_sa_month.csv
#   https://files.zillowstatic.com/research/public_csvs/zori/Metro_zori_uc_sfrcondo_sm_sa_month.csv
ZILLOW_ZHVI_URL=
ZILLOW_ZORI_URL=

# Arrived's public catalogue JSON API (no key) — the manual offerings-refresh
# source (§10): POST /api/admin/refresh-offerings upserts buyable offerings and
# retires the seed catalog on first success. Override only to pin or test.
ARRIVED_API_URL=https://abacus.arrivedhomes.com
